# ==============================================================================
# Multi-Agent Planning Suite - Environment Configuration Template
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# LLM Provider Selection
# Options: 'openai', 'groq', 'ollama'
MODEL_PROVIDER=openai

# OpenAI Provider configuration
# Required if MODEL_PROVIDER is 'openai'
OPENAI_API_KEY=your-openai-api-key-here

# Groq Provider configuration
# Required if MODEL_PROVIDER is 'groq'
GROQ_API_KEY=your-groq-api-key-here

# Ollama Provider configuration
# Optional, defaults to http://localhost:11434 and ollama/llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/llama3
